APP_NAME=Autoscale Local API
APP_VERSION=0.1.0
DEBUG=true

HOST=127.0.0.1
PORT=8000

DATABASE_URL=postgresql+asyncpg://127.0.0.1:5432/autoscale_local

# Ed25519 public key (base64). Generate: python -m scripts.generate_keys
LICENSE_PUBLIC_KEY=
LICENSE_FILE_PATH=./data/license.lic
LICENSE_STATE_PATH=./data/license_state.json

OWNER_ADMIN_URL=http://127.0.0.1:8090

CORS_ORIGINS=http://127.0.0.1:8081,http://localhost:8081,http://127.0.0.1:8080,http://localhost:8080

SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

ALLOW_LAN=false
